{
  "name": "studentpay-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:student",
    "dev:student": "cross-env NEXT_PUBLIC_APP_INSTANCE=student next dev",
    "dev:admin": "cross-env NEXT_PUBLIC_APP_INSTANCE=admin next dev",
    "build": "npm run build:student",
    "build:student": "cross-env NEXT_PUBLIC_APP_INSTANCE=student next build",
    "build:admin": "cross-env NEXT_PUBLIC_APP_INSTANCE=admin next build",
    "start": "cross-env NEXT_PUBLIC_APP_INSTANCE=student next start",
    "start:admin": "cross-env NEXT_PUBLIC_APP_INSTANCE=admin next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.84.0",
    "@tanstack/react-query": "^5.90.10",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.554.0",
    "next": "16.0.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.66.1",
    "recharts": "^3.5.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.13",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

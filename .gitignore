# ─── Dependencies ────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Environment / Secrets ───────────────────────────────
# Never commit real credentials — copy env.example → .env to get started
.env
.env.*
!.env.example
!env.example

# ─── Build outputs ───────────────────────────────────────
/dist
/dist-exe
/out
/build
/.next

# ─── Logs ────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── TypeScript ──────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── OS / Editor ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vercel

# ─── Testing ─────────────────────────────────────────────
/coverage

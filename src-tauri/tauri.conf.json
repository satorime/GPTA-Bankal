{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "studentpay-tracker",
  "version": "0.1.0",
  "identifier": "com.bankal.studentpay",
  "build": {
    "frontendDist": "../desktop-shell",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "node scripts/tauri-dev.mjs",
    "beforeBuildCommand": "node scripts/tauri-build.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "studentpay-tracker",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources"
    ]
  }
}

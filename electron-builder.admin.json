{
  "appId": "com.bankal.studentpay.admin",
  "productName": "StudentPay - Admin",
  "directories": {
    "output": "dist-exe/admin"
  },
  "files": [
    "electron/**",
    "dist/**",
    "public/**",
    "package.json"
  ],
  "asar": true,
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }],
    "icon": "public/icon.ico",
    "signAndEditExecutable": false
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "shortcutName": "StudentPay Admin"
  }
}

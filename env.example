# ─────────────────────────────────────────────────────
# Rename this file to .env and fill in your values.
# VITE_ prefix is required — Vite only exposes these to the app.
# ─────────────────────────────────────────────────────

# Your Supabase project URL
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"

# Supabase anon (public) key
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Supabase service role key (full access — keep this private)
VITE_SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional: pre-fill the student lookup with this code (student portal only)
VITE_DEMO_STUDENT_CODE="STU-0001"

# Which portal to build: "student" or "admin"
# This is set automatically by the build scripts — do not change here.
# VITE_APP_INSTANCE="student"
